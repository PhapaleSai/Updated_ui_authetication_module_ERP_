{
  "name": "pvg-frontend",
  "version": "1.0.0",
  "description": "PVG Frontend Monorepo",
  "scripts": {
    "dev:user": "cd user && npm run dev",
    "dev:admin": "cd admin && npm run dev",
    "dev": "npx concurrently \"npm run dev:user\" \"npm run dev:admin\""
  },
  "devDependencies": {
    "npm-run-all": "^4.1.5"
  }
}
